generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProviderType {
  chat_subscription
  api_key
}

enum ProviderKey {
  openai
  openai_compatible
  anthropic
  google
  perplexity
}

enum AuthMode {
  api_key
  oauth
  session_cookie
}

enum ProviderStatus {
  active
  disabled
}

enum AccountStatus {
  active
  expiring
  expired
  suspended
  rate_limited
  unknown
}

enum KeyStatus {
  active
  invalid
  revoked
}

enum RenewalType {
  manual
  auto
}

enum QuotaType {
  requests
  tokens
  seats
  mixed
}

enum AccessRole {
  consumer
  manager
}

enum UsageAction {
  chat
  api_call
  login
  refresh
}

enum UsageResult {
  success
  fail
  rate_limited
}

enum AlertType {
  expiry_soon
  quota_exceeded
  key_invalid
}

enum Severity {
  low
  medium
  high
}

model Provider {
  id           String         @id @default(uuid())
  key          ProviderKey    @default(openai_compatible)
  name         String         @unique
  type         ProviderType
  authMode     AuthMode
  status       ProviderStatus @default(active)
  apiBaseUrl   String?
  chatPath     String?
  extraHeaders Json?
  accounts     Account[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Account {
  id              String           @id @default(uuid())
  providerId      String
  provider        Provider         @relation(fields: [providerId], references: [id])
  label           String
  plan            String?
  currentKeyId    String?          @unique
  currentKey      AccountKey?      @relation("current_key", fields: [currentKeyId], references: [id])
  renewalType     RenewalType      @default(manual)
  startDate       DateTime?
  expiryDate      DateTime?
  quotaType       QuotaType        @default(requests)
  quotaLimit      Json?
  status          AccountStatus    @default(unknown)
  slaPriority     Int              @default(100)
  notes           String?
  accesses        AccountAccess[]
  usageEvents     UsageEvent[]
  usageAggregates UsageAggregate[]
  alerts          Alert[]
  keys            AccountKey[]     @relation("account_keys")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AccountKey {
  id             String    @id @default(uuid())
  accountId      String
  account        Account   @relation("account_keys", fields: [accountId], references: [id])
  currentFor     Account?  @relation("current_key")
  tokenEncrypted Bytes
  tokenLast4     String
  status         KeyStatus @default(active)
  isPrimary      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([accountId])
  @@index([status])
}

model User {
  id        String          @id @default(uuid())
  email     String          @unique
  name      String?
  password  String
  status    String          @default("active")
  roles     UserRole[]
  accesses  AccountAccess[]
  usage     UsageEvent[]
  audits    AuditLog[]      @relation("audit_actor")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Role {
  id    String     @id @default(uuid())
  name  String     @unique
  users UserRole[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model AccountAccess {
  id          String     @id @default(uuid())
  accountId   String
  userId      String
  role        AccessRole @default(consumer)
  limitPolicy Json?
  active      Boolean    @default(true)
  account     Account    @relation(fields: [accountId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([accountId])
}

model UsageEvent {
  id             String      @id @default(uuid())
  timestamp      DateTime    @default(now())
  accountId      String
  userId         String
  action         UsageAction
  requestTokens  Int?
  responseTokens Int?
  totalTokens    Int?
  costEstimate   Float?
  result         UsageResult @default(success)
  meta           Json?
  account        Account     @relation(fields: [accountId], references: [id])
  user           User        @relation(fields: [userId], references: [id])

  @@index([timestamp])
  @@index([accountId])
  @@index([userId])
}

model UsageAggregate {
  id          String   @id @default(uuid())
  date        DateTime
  accountId   String
  requests    Int      @default(0)
  tokens      Int      @default(0)
  failures    Int      @default(0)
  rateLimited Int      @default(0)
  account     Account  @relation(fields: [accountId], references: [id])

  @@unique([date, accountId])
  @@index([date])
}

model Alert {
  id         String    @id @default(uuid())
  type       AlertType
  severity   Severity
  accountId  String
  message    String
  isResolved Boolean   @default(false)
  account    Account   @relation(fields: [accountId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([isResolved])
  @@index([severity])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  meta       Json?
  actor      User     @relation("audit_actor", fields: [actorId], references: [id])
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}
